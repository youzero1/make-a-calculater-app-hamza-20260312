<file path="calculator-app/src/lib/calculatorUtils.ts">
/**
 * Pure utility functions for the calculator logic.
 * Extracted for testability.
 */

/**
 * Format a numeric result to a display string.
 * Returns 'Error' for non-finite or NaN values.
 */
export function formatResult(value: number): string {
  if (!isFinite(value)) return 'Error';
  if (isNaN(value)) return 'Error';
  const str = parseFloat(value.toPrecision(12)).toString();
  return str;
}

/**
 * Safely evaluate a math expression string.
 * Only allows numbers, operators (+, -, *, /), parentheses, dots, and spaces.
 * Throws if the expression contains invalid characters.
 */
export function safeEval(expr: string): number {
  if (!/^[\d+\-*/().\s]+$/.test(expr)) {
    throw new Error('Invalid expression: contains disallowed characters');
  }
  // eslint-disable-next-line no-new-func
  return Function('"use strict"; return (' + expr + ')')() as number;
}

/**
 * Convert a display expression (with × and ÷) to an eval-safe expression (with * and /).
 */
export function toEvalExpression(displayExpr: string): string {
  return displayExpr.replace(/×/g, '*').replace(/÷/g, '/');
}

/**
 * Get the display symbol for a math operator.
 */
export function getDisplayOperator(op: string): string {
  if (op === '*') return '×';
  if (op === '/') return '÷';
  return op;
}

/**
 * Check if an expression involves division by zero.
 */
export function isDivisionByZero(evalExpr: string): boolean {
  // Match / followed by optional spaces and a 0 that's at end or followed by space/non-digit
  const match = evalExpr.match(/\/\s*(\d+\.?\d*)/g);
  if (!match) return false;
  return match.some(m => {
    const num = parseFloat(m.replace('/', '').trim());
    return num === 0;
  });
}

/**
 * Evaluate a full calculator expression and return the result string.
 */
export function evaluateExpression(displayExpression: string, currentValue: string): string {
  const fullExpression = displayExpression + ' ' + currentValue;
  const evalExpression = toEvalExpression(fullExpression);

  try {
    if (isDivisionByZero(evalExpression)) {
      return 'Error: Div/0';
    }
    const res = safeEval(evalExpression);
    return formatResult(res);
  } catch {
    return 'Error';
  }
}

/**
 * Process a digit input given the current state.
 */
export function processDigitInput(
  digit: string,
  currentValue: string,
  waitingForOperand: boolean
): string {
  if (waitingForOperand) {
    return digit;
  }
  if (currentValue === '0') return digit;
  if (currentValue.length >= 15) return currentValue;
  return currentValue + digit;
}

/**
 * Process a decimal input given the current state.
 */
export function processDecimalInput(
  currentValue: string,
  waitingForOperand: boolean
): string {
  if (waitingForOperand) {
    return '0.';
  }
  if (!currentValue.includes('.')) {
    return currentValue + '.';
  }
  return currentValue;
}

/**
 * Process a backspace given the current value.
 */
export function processBackspace(currentValue: string): string {
  if (currentValue.length <= 1) return '0';
  return currentValue.slice(0, -1);
}

/**
 * Process a percent operation on the current value.
 */
export function processPercent(currentValue: string): string {
  const val = parseFloat(currentValue) / 100;
  return formatResult(val);
}
